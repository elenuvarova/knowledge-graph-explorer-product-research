PORT=3001
NODE_ENV=development

# Leave DATABASE_URL blank locally — the backend will use SQLite automatically.
# On Render, this is injected from the Postgres database; you never set it manually.
# DATABASE_URL=

# Required for AI topic expansion and opportunity descriptions.
# Get your key at https://console.anthropic.com
# Without it, topic expansion falls back to a simple keyword split (still works).
# ANTHROPIC_API_KEY=sk-ant-...
